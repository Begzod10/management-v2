# ── Management DB (runs inside Docker as "db" service) ────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@db:5432/management
POSTGRES_DB=management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# ── External DBs (Gennis & Turon — running on HOST, not in Docker) ───────────
# These are the system PostgreSQL instances on the server (127.0.0.1).
# From inside Docker, reach them via host.docker.internal (see docker-compose extra_hosts).
# IMPORTANT: special chars in password must be URL-encoded  (#→%23  @→%40)
GENNIS_DB_URL=postgresql://postgres:or9T%23u-x5PZo--@host.docker.internal:5432/gennis
TURON_DB_URL=postgresql://postgres:or9T%23u-x5PZo--@host.docker.internal:5432/turon

# Alembic v2 chain points here (DATABASE_URL_V2)
DATABASE_URL_V2=postgresql://postgres:CHANGE_ME@db:5432/management

# ── Redis (runs inside Docker as "redis" service) ────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
MOBILE_CLIENT_ID=
GOOGLE_ALLOWED_CLIENT_IDS=
APPLE_ALLOWED_CLIENT_IDS=

# ── App ───────────────────────────────────────────────────────────────────────
BASE_URL=https://management.gennis.uz

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_PROXY=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
